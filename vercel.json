{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "functions": {
    "api/logmeal/analyze.js": {
      "maxDuration": 30
    },
    "api/meals/index.js": {
      "maxDuration": 60
    },
    "api/meals/[id].js": {
      "maxDuration": 30
    },
    "api/gemini/analyze.js": {
      "maxDuration": 60
    }
  }
}
